rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Service requests: anyone can create, only authenticated admins can read/update/delete
    match /serviceRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['fname', 'lname', 'email', 'service', 'message'])
                    && request.resource.data.fname is string
                    && request.resource.data.email is string
                    && request.resource.data.message is string;
      allow read, update, delete: if request.auth != null;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
